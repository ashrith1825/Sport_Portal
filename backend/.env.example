# MongoDB connection string (use your Atlas/managed cluster URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/sport_portal?retryWrites=true&w=majority
MONGODB_DB=sport_portal

# JWT secret used for signing tokens (change to a long random value in production)
JWT_SECRET=replace_with_a_strong_secret

# Port the API should listen on (Render/Heroku provide their own PORT env)
PORT=8080

# Comma-separated allowed origins for CORS
# Example: http://localhost:5173,https://sport-portal-omega.vercel.app
# Note: this only affects browser CORS. Atlas network access also needs a whitelist entry.
ALLOWED_ORIGINS=https://sport-portal-omega.vercel.app
